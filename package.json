{
  "name": "ibira.js",
  "version": "0.3.1-alpha",
  "description": "A JavaScript library for fetching and caching API data with observer pattern support",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:verbose": "jest --verbose",
    "test:node": "jest --config jest.node.config.mjs",
    "build": "tsup",
    "validate": "npx tsc --noEmit",
    "test:all": "npm run validate && npm test",
    "prepublishOnly": "npm run validate && npm test && npm run build",
    "lint": "eslint src/ __tests__/"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "transform": {
      "^.+\\.ts$": "ts-jest",
      "^.+\\.js$": "babel-jest"
    },
    "moduleFileExtensions": [
      "ts",
      "js",
      "json",
      "node"
    ],
    "moduleNameMapper": {
      "^(.*)\\.js$": "$1"
    },
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/index.ts",
      "!**/node_modules/**"
    ],
    "coverageReporters": [
      "text",
      "lcov",
      "html"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 75,
        "functions": 75,
        "lines": 75,
        "statements": 75
      }
    }
  },
  "keywords": [
    "api",
    "fetch",
    "cache",
    "observer",
    "javascript",
    "http",
    "rest",
    "async"
  ],
  "author": "Marcelo Pereira Barbosa",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mpbarbosa/ibira.js.git"
  },
  "bugs": {
    "url": "https://github.com/mpbarbosa/ibira.js/issues"
  },
  "homepage": "https://github.com/mpbarbosa/ibira.js#readme",
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "@types/jest": "^30.0.0",
    "babel-jest": "^29.7.0",
    "eslint": "^9.39.4",
    "globals": "^17.4.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "ts-jest": "^29.4.6",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
