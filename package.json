{
  "name": "ibira.js",
  "version": "0.5.0",
  "description": "A JavaScript library for fetching and caching API data with observer pattern support",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:verbose": "jest --verbose",
    "test:node": "jest --config jest.node.config.mjs",
    "build": "tsup",
    "validate": "npx tsc --noEmit",
    "version:sync": "node scripts/sync-version.js",
    "version:check": "node scripts/sync-version.js --check",
    "test:all": "npm run version:check && npm run validate && npm test",
    "prepublishOnly": "npm run validate && npm test && npm run build",
    "lint": "eslint src/ __tests__/ test/",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:md": "markdownlint-cli2 \"**/*.md\"",
    "benchmark": "npm run build && node scripts/benchmark.mjs",
    "audit": "npm audit --audit-level=high",
    "prepare": "husky"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/__tests__/helpers\\.js$"
    ],
    "transform": {
      "^.+\\.ts$": "ts-jest",
      "^.+\\.js$": "babel-jest"
    },
    "moduleFileExtensions": [
      "ts",
      "js",
      "json",
      "node"
    ],
    "moduleNameMapper": {
      "^(.*)\\.js$": "$1"
    },
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/index.ts",
      "!**/node_modules/**"
    ],
    "coverageReporters": [
      "text",
      "lcov",
      "html"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 75,
        "functions": 75,
        "lines": 75,
        "statements": 75
      }
    }
  },
  "keywords": [
    "api",
    "fetch",
    "cache",
    "observer",
    "javascript",
    "http",
    "rest",
    "async"
  ],
  "author": "Marcelo Pereira Barbosa",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mpbarbosa/ibira.js.git"
  },
  "bugs": {
    "url": "https://github.com/mpbarbosa/ibira.js/issues"
  },
  "homepage": "https://github.com/mpbarbosa/ibira.js#readme",
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@babel/preset-env": "^7.23.0",
    "@types/jest": "^30.0.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "babel-jest": "^29.7.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jest": "29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "markdownlint-cli2": "^0.22.1",
    "prettier": "^3.8.1",
    "ts-jest": "29.4.6",
    "tsup": "^8.5.1",
    "typescript": "5.9.3"
  },
  "dependencies": {
    "bessa_patterns.ts": "^0.13.0"
  }
}
